# Homebrew Environment Setup
# Only setup if Homebrew is installed
if [ -d "/home/linuxbrew/.linuxbrew" ] || [ -d "$HOME/.linuxbrew" ]; then
    # Set HOMEBREW_PATH safely
    if [ -d "/home/linuxbrew/.linuxbrew" ]; then
        export HOMEBREW_PATH="/home/linuxbrew/.linuxbrew"
    else
        export HOMEBREW_PATH="$HOME/.linuxbrew"
    fi

    # Setup PATH
    PATH=/sbin:/bin:/usr/sbin:/usr/bin:/usr/syno/sbin:/usr/syno/bin:/usr/local/sbin:/usr/local/bin
    
    # Homebrew directories to add to PATH
    directories=(
      "$HOMEBREW_PATH/opt/glibc/sbin"
      "$HOMEBREW_PATH/opt/glibc/bin"
      "$HOMEBREW_PATH/opt/binutils/bin"
      "$HOMEBREW_PATH/sbin"
      "$HOMEBREW_PATH/bin"
    )
    
    # Add Ruby gem binaries if present
    if [ -d "$HOMEBREW_PATH/lib/ruby/gems" ]; then
        for gem_bin in "$HOMEBREW_PATH"/lib/ruby/gems/*/bin; do
            [ -d "$gem_bin" ] && directories+=("$gem_bin")
        done
    fi
    
    # Clean PATH and prepend Homebrew directories
    replace_in_path() {
      local cleaned_path=""
      local new_path="$PATH"
      local new_dir
      for new_dir in "${directories[@]}"; do
        [ -d "$new_dir" ] || continue
        # Remove existing instances
        new_path=$(echo "$new_path" | awk -v RS=: -v ORS=: '$0 != "'"$new_dir"'"' | sed 's/:$//')
        # Prepend
        cleaned_path="$new_dir:$cleaned_path"
      done
      export PATH="${cleaned_path}${new_path}"
    }
    replace_in_path
    
    # Set compiler flags
    export LDFLAGS="-L$HOMEBREW_PATH/opt/glibc/lib"
    export CPPFLAGS="-I$HOMEBREW_PATH/opt/glibc/include"
    export XDG_CONFIG_HOME="$HOME/.config"
    export HOMEBREW_GIT_PATH=$HOMEBREW_PATH/bin/git
    
    # Set up GCC symlinks to latest version
    if [ -d "$HOMEBREW_PATH/opt/gcc/bin" ]; then
        max_version=$(/bin/ls -d $HOMEBREW_PATH/opt/gcc/bin/gcc-* 2>/dev/null | grep -oE '[0-9]+$' | sort -nr | head -n1 2>/dev/null || echo "")
        if [ -n "$max_version" ]; then
            ln -sf "$HOMEBREW_PATH/bin/gcc-$max_version" "$HOMEBREW_PATH/bin/gcc" 2>/dev/null || true
            for ((i = 11; i < max_version; i++)); do
                ln -sf "$HOMEBREW_PATH/bin/gcc-$max_version" "$HOMEBREW_PATH/bin/gcc-$i" 2>/dev/null || true
            done
        fi
    fi
    
    # Initialize Homebrew
    eval "$($HOMEBREW_PATH/bin/brew shellenv 2>/dev/null)" || true
    
    # Source fzf-git.sh if available
    [ -f "$HOME/.scripts/fzf-git.sh" ] && source "$HOME/.scripts/fzf-git.sh"
    
    # Perl local::lib setup
    if command -v perl >/dev/null 2>&1 && perl -Mlocal::lib -e '1' 2>/dev/null; then
        eval "$(perl -I$HOME/perl5/lib/perl5 -Mlocal::lib=$HOME/perl5 2>/dev/null)" || true
    fi
    
    # SAFE ZSH LAUNCH - Only in interactive non-SSH sessions
    if [[ -x "$HOMEBREW_PATH/bin/zsh" && -t 0 && -z "$SSH_CONNECTION" && -z "$SSH_TTY" && -z "$SSH_CLIENT" ]]; then
        exec "$HOMEBREW_PATH/bin/zsh" -l
    fi
fi

